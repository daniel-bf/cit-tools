{
  "name": "cit-tools",
  "displayName": "Cit — Single File Version Control",
  "description": "Version control for individual files and config environment management. Track named snapshots, switch between configs, without touching git.",
  "version": "0.2.0",
  "publisher": "daniel-bf",
  "repository": {
    "type": "git",
    "url": "https://github.com/daniel-bf/cit-tools.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": ["version control", "config management", "snapshots", "cit", "environments"],
  "activationEvents": [],
  "main": "./out/extension.js",

  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cittools-sidebar",
          "title": "Cit",
          "icon": "resources/cit.svg"
        }
      ]
    },
    "views": {
      "cittools-sidebar": [
        {
          "id": "cittools.fileTreeView",
          "name": "Files"
        },
        {
          "id": "cittools.versionView",
          "name": "Versions"
        },
        {
          "id": "cittools.envView",
          "name": "Environments"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cittools.refresh",
          "when": "view == cittools.fileTreeView",
          "group": "navigation"
        },
        {
          "command": "cittools.add",
          "when": "view == cittools.versionView",
          "group": "navigation"
        },
        {
          "command": "cittools.commit",
          "when": "view == cittools.versionView",
          "group": "navigation"
        },
        {
          "command": "cittools.envSnapshot",
          "when": "view == cittools.envView",
          "group": "navigation"
        },
        {
          "command": "cittools.envInit",
          "when": "view == cittools.envView",
          "group": "navigation@2"
        },
        {
          "command": "cittools.refresh",
          "when": "view == cittools.envView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "cittools.init",
          "when": "view == cittools.fileTreeView && viewItem == file-untracked",
          "group": "inline"
        },
        {
          "command": "cittools.init",
          "when": "view == cittools.fileTreeView && viewItem == file-tracked",
          "group": "cit@1"
        },
        {
          "command": "cittools.add",
          "when": "view == cittools.fileTreeView && viewItem == file-tracked",
          "group": "inline"
        },
        {
          "command": "cittools.commit",
          "when": "view == cittools.fileTreeView && viewItem == file-tracked",
          "group": "inline"
        },
        {
          "command": "cittools.switch",
          "when": "view == cittools.versionView && viewItem == version",
          "group": "inline"
        },
        {
          "command": "cittools.remove",
          "when": "view == cittools.versionView && viewItem == version",
          "group": "inline"
        },
        {
          "command": "cittools.envSwitch",
          "when": "view == cittools.envView && viewItem == env",
          "group": "inline"
        },
        {
          "command": "cittools.envDelete",
          "when": "view == cittools.envView && viewItem == env",
          "group": "inline"
        },
        {
          "command": "cittools.envSnapshot",
          "when": "view == cittools.envView && viewItem == env-current",
          "group": "inline"
        }
      ]
    },
    "commands": [
      {
        "command": "cittools.init",
        "title": "Cit: Initialize",
        "icon": "$(add)"
      },
      {
        "command": "cittools.add",
        "title": "Cit: Save Version",
        "icon": "$(save)"
      },
      {
        "command": "cittools.commit",
        "title": "Cit: Commit Changes",
        "icon": "$(git-commit)"
      },
      {
        "command": "cittools.switch",
        "title": "Cit: Switch Version",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "cittools.remove",
        "title": "Cit: Remove Version",
        "icon": "$(trash)"
      },
      {
        "command": "cittools.refresh",
        "title": "Cit: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "cittools.selectFile",
        "title": "Cit: Select File"
      },
      {
        "command": "cittools.envInit",
        "title": "Cit: Init Environment",
        "icon": "$(add)"
      },
      {
        "command": "cittools.envTrack",
        "title": "Cit: Track File in Environment"
      },
      {
        "command": "cittools.envSnapshot",
        "title": "Cit: Save Environment",
        "icon": "$(save)"
      },
      {
        "command": "cittools.envSwitch",
        "title": "Cit: Switch Environment",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "cittools.envDelete",
        "title": "Cit: Delete Environment",
        "icon": "$(trash)"
      }
    ]
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}
